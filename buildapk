#!/bin/bash

# -------------------------------
# HTML_to_APK build tool
# -------------------------------

if [ "$#" -ne 3 ]; then
    echo "Uso:"
    echo "buildapk <nombre_carpeta> <id_app> \"<nombre_visible>\""
    exit 1
fi

FOLDER_NAME="$1"
APP_ID="$2"
APP_NAME="$3"

REQUIRED_FILES=(index.html style.css script.js icon.png splash.png)

echo "Verificando archivos..."

for file in "${REQUIRED_FILES[@]}"; do
    if [ ! -f "$file" ]; then
        echo "Error: falta $file"
        exit 1
    fi
done

echo "Todos los archivos encontrados."

# --------------------------------
# Verificar dependencias
# --------------------------------

if ! command -v cordova &> /dev/null; then
    echo "Cordova no está instalado."
    exit 1
fi

if ! command -v cordova-res &> /dev/null; then
    echo "Instalando cordova-res..."
    npm install -g cordova-res
fi

if ! command -v ffmpeg &> /dev/null; then
    echo "Instalando ffmpeg..."
    sudo dnf install -y ffmpeg
fi

# --------------------------------
# Redimensionar imágenes
# --------------------------------

echo "Verificando imágenes..."

SPLASH_DIM=$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 splash.png)
SW=$(echo "$SPLASH_DIM" | cut -dx -f1)
SH=$(echo "$SPLASH_DIM" | cut -dx -f2)

if [ "$SW" -lt 2732 ] || [ "$SH" -lt 2732 ]; then
    echo "Redimensionando splash..."
    mv splash.png splash.png.bak
    ffmpeg -i splash.png.bak -vf "scale=2732:2732:force_original_aspect_ratio=decrease,pad=2732:2732:(ow-iw)/2:(oh-ih)/2" -y splash.png
fi

ICON_DIM=$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 icon.png)
IW=$(echo "$ICON_DIM" | cut -dx -f1)
IH=$(echo "$ICON_DIM" | cut -dx -f2)

if [ "$IW" -lt 1024 ] || [ "$IH" -lt 1024 ]; then
    echo "Redimensionando icon..."
    mv icon.png icon.png.bak
    ffmpeg -i icon.png.bak -vf "scale=1024:1024:force_original_aspect_ratio=decrease,pad=1024:1024:(ow-iw)/2:(oh-ih)/2" -y icon.png
fi

# --------------------------------
# Crear proyecto Cordova
# --------------------------------

echo "Creando proyecto..."

cordova create "$FOLDER_NAME" "$APP_ID" "$APP_NAME" || exit 1

rm -rf "$FOLDER_NAME/www"
mkdir "$FOLDER_NAME/www"

mv index.html style.css script.js "$FOLDER_NAME/www/"

mkdir -p "$FOLDER_NAME/resources"

mv icon.png splash.png "$FOLDER_NAME/resources/"

cd "$FOLDER_NAME" || exit 1

# --------------------------------
# Añadir Android
# --------------------------------

echo "Añadiendo Android..."

cordova platform add android || exit 1

# --------------------------------
# Plugins necesarios
# --------------------------------

echo "Instalando plugins..."

cordova plugin add cordova-plugin-splashscreen
cordova plugin add cordova-plugin-whitelist

# --------------------------------
# Configurar config.xml
# --------------------------------

echo "Configurando splash..."

sed -i '/<widget/a \
    <preference name="SplashScreenDelay" value="3000" />\
    <preference name="FadeSplashScreenDuration" value="500" />\
    <preference name="AndroidWindowSplashScreenAnimatedIcon" value="resources/splash.png" />\
    <preference name="AndroidWindowSplashScreenBackground" value="#ffffff" />\
' config.xml

# --------------------------------
# Generar iconos y splash
# --------------------------------

echo "Generando recursos..."

cordova-res android

cordova prepare

# --------------------------------
# Compilar APK
# --------------------------------

echo "Construyendo APK..."

cordova build android

APK_PATH="platforms/android/app/build/outputs/apk/debug/app-debug.apk"

if [ -f "$APK_PATH" ]; then
    mv "$APK_PATH" .
    echo ""
    echo "APK generada:"
    echo "$FOLDER_NAME/app-debug.apk"
else
    echo "No se encontró la APK."
fi

echo "Proceso completado."